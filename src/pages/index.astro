---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/sections/Hero.astro';
import Process from '../components/sections/Process.astro';
import Benefits from '../components/sections/Benefits.astro';
import Testimonials from '../components/sections/Testimonials.astro';
import Pricing from '../components/sections/Pricing.astro';
import Footer from '../components/sections/Footer.astro';
import CalEmbed from '../components/islands/CalEmbed.tsx';
import Card from '../components/ui/Card.astro';
---

<BaseLayout>
  <main>
    <Hero />
    <Process />
    <Benefits />
    <Testimonials />
    <Pricing />

    <section id='agendar' class='py-20'>
      <div class='container-wide'>
        <h2 class='text-3xl md:text-4xl font-heading text-center mb-4'>
          Agende sua <span class='gradient-gold bg-clip-text text-transparent'>Leitura</span>
        </h2>
        <p class='text-muted-foreground text-center mb-16 max-w-xl mx-auto'>
          Escolha o melhor horário para você e reserve sua sessão.
        </p>

        <Card variant='glass' padding='lg' class='max-w-4xl mx-auto'>
          <CalEmbed calLink='patriciataques/leitura-de-tarot' calNamespace='tarot-booking' client:visible />
        </Card>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>