---
import WhatsAppButton from '../ui/WhatsAppButton.astro';

const calLink = import.meta.env.PUBLIC_CALCOM_LINK || 'patriciataques/leitura-de-tarot';
---

<section class='py-20 scroll-reveal' id='agendar'>
  <div class='container-wide'>
    <h2 class='text-3xl md:text-4xl font-[family-name:var(--font-heading)] text-center mb-4 scroll-reveal'>
      Agende sua <span class='gradient-gold-text'>Leitura</span>
    </h2>
    <p class='text-muted-foreground text-center mb-12 max-w-xl mx-auto scroll-reveal'>
      Escolha o melhor horário para você e reserve sua sessão de tarot.
    </p>

    <div class='max-w-4xl mx-auto'>
      <div class='grid md:grid-cols-2 gap-8 stagger-children'>
        <div class='space-y-4'>
          <div class='info-card scroll-reveal'>
            <div class='info-icon'>🔮</div>
            <div>
              <h3>Sessão Online</h3>
              <p>Via áudio ou videochamada</p>
            </div>
          </div>
          <div class='info-card scroll-reveal'>
            <div class='info-icon'>📸</div>
            <div>
              <h3>Material Incluso</h3>
              <p>Fotos, áudio e análise escrita</p>
            </div>
          </div>
          <div class='info-card scroll-reveal'>
            <div class='info-icon'>⏱️</div>
            <div>
              <h3>60 Minutos</h3>
              <p>Leitura completa e direcionamento</p>
            </div>
          </div>
        </div>

        <div class='flex flex-col items-center justify-center gap-6 scroll-reveal'>
          <WhatsAppButton size='lg' class='w-full max-w-sm'>
            Agendar via WhatsApp
          </WhatsAppButton>

          <button
            class='cal-button w-full max-w-sm'
            data-cal-link={calLink}
            data-cal-modal
            data-cal-config='{&quot;theme&quot;:&quot;dark&quot;,&quot;styles&quot;:{&quot;background&quot;:&quot;#18181B&quot;,&quot;primaryColor&quot;:&quot;#D4A12C&quot;}}'
          >
            <span class='cal-button-icon'>📅</span>
            <span class='cal-button-text'>Agendar Online</span>
          </button>

          <p class='text-muted-foreground text-sm'>
            ou entre em contato diretamente
          </p>
        </div>
      </div>

      <div class='booking-trust scroll-reveal mt-12'>
        <div class='trust-item'>
          <span class='trust-icon'>✓</span>
          <span>Confirmação imediata</span>
        </div>
        <div class='trust-item'>
          <span class='trust-icon'>✓</span>
          <span>+300 leituras realizadas</span>
        </div>
        <div class='trust-item'>
          <span class='trust-icon'>✓</span>
          <span>Avaliação 5 estrelas</span>
        </div>
      </div>
    </div>
  </div>
</section>

<script async src='https://embed.cal.com/embed.js'></script>

<style>
  .info-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.5rem;
    background: var(--background-card);
    border: 1px solid var(--border);
    border-radius: 1rem;
    transition: all 0.3s ease;
  }

  .info-card:hover {
    border-color: var(--gold-700);
    transform: translateX(4px);
  }

  .info-icon {
    font-size: 1.5rem;
    width: 3rem;
    height: 3rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--gold-950);
    border-radius: 0.75rem;
  }

  .info-card h3 {
    font-family: var(--font-heading);
    font-weight: 600;
    margin-bottom: 0.25rem;
  }

  .info-card p {
    font-size: 0.875rem;
    color: var(--muted-foreground);
    margin: 0;
  }

  .cal-button {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    width: 100%;
    max-width: 320px;
    padding: 1rem 1.5rem;
    background: var(--background-card);
    color: var(--foreground);
    font-size: 1rem;
    font-weight: 600;
    border: 2px solid var(--gold-500);
    border-radius: 0.75rem;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .cal-button:hover {
    background: var(--gold-500);
    color: var(--background);
    transform: translateY(-2px);
    box-shadow: var(--shadow-gold);
  }

  .cal-button-icon {
    font-size: 1.25rem;
  }

  .booking-trust {
    display: flex;
    justify-content: center;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .trust-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: var(--muted-foreground);
  }

  .trust-icon {
    color: var(--gold-500);
    font-weight: bold;
  }
</style>