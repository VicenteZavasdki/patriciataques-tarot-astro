---
import PaymentForm from '../islands/PaymentForm';
---

<section class='py-20 scroll-reveal' id='payment'>
  <div class='container-wide'>
    <h2 class='text-3xl md:text-4xl font-[family-name:var(--font-heading)] text-center mb-4 scroll-reveal'>
      Pagamento <span class='gradient-gold-text'>Seguro</span>
    </h2>
    <p class='text-muted-foreground text-center mb-12 max-w-xl mx-auto scroll-reveal'>
      Reserve sua sessão com pagamento seguro via Stripe. Aceitamos cartões de crédito e débito.
    </p>

    <div class='scroll-reveal'>
      <PaymentForm client:visible />
    </div>

    <div class='mt-12 flex items-center justify-center gap-8 flex-wrap scroll-reveal'>
      <div class='flex items-center gap-2'>
        <svg class='w-6 h-6 text-gold-500' fill='none' stroke='currentColor' viewBox='0 0 24 24'>
          <path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z' />
        </svg>
        <span class='text-sm text-muted-foreground'>SSL Seguro</span>
      </div>
      <div class='flex items-center gap-2'>
        <svg class='w-6 h-6 text-gold-500' fill='none' stroke='currentColor' viewBox='0 0 24 24'>
          <path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z' />
        </svg>
        <span class='text-sm text-muted-foreground'>Stripe Protegido</span>
      </div>
      <div class='flex items-center gap-2'>
        <svg class='w-6 h-6 text-gold-500' fill='none' stroke='currentColor' viewBox='0 0 24 24'>
          <path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z' />
        </svg>
        <span class='text-sm text-muted-foreground'>Cartões aceitos</span>
      </div>
    </div>
  </div>
</section>