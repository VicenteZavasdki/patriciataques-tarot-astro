---
import { processSteps } from '../../lib/constants';
---

<section class='py-20 bg-background-elevated'>
  <div class='container-wide'>
    <h2 class='text-3xl md:text-4xl font-[family-name:var(--font-heading)] text-center mb-4 scroll-reveal'>
      Como <span class='gradient-gold-text'>Funciona</span>
    </h2>
    <p class='text-muted-foreground text-center mb-16 max-w-xl mx-auto scroll-reveal'>
      Três passos simples para iniciar sua jornada de autoconhecimento.
    </p>

    <div class='grid md:grid-cols-3 gap-8 stagger-children'>
      {processSteps.map((step, index) => (
        <div class='relative scroll-reveal'>
          <div class='absolute -left-4 -top-4 w-14 h-14 rounded-full bg-gold-500/20 flex items-center justify-center text-gold-500 font-bold text-xl font-[family-name:var(--font-display)]'>
            {step.step}
          </div>

          <div class='bg-background-card border border-border rounded-2xl p-8 h-full transition-all duration-300 hover:border-gold-700 hover:shadow-lg hover:shadow-gold-500/5 hover:-translate-y-1'>
            <h3 class='text-xl font-[family-name:var(--font-heading)] mb-4 text-foreground'>
              {step.title}
            </h3>
            <p class='text-muted-foreground leading-relaxed'>
              {step.description}
            </p>
          </div>

          {index < processSteps.length - 1 && (
            <div class='hidden md:block absolute top-1/2 -right-4 transform -translate-y-1/2 text-gold-700'>
              <svg class='w-8 h-8' fill='none' viewBox='0 0 24 24' stroke='currentColor'>
                <path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M9 5l7 7-7 7' />
              </svg>
            </div>
          )}
        </div>
      ))}
    </div>
  </div>
</section>