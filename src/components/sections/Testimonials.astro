---
import Card from '../ui/Card.astro';
import Badge from '../ui/Badge.astro';
import Button from '../ui/Button.astro';
import { testimonials } from '../../data/testimonials';
---

<section class='py-20 bg-background-elevated' id='depoimentos'>
  <div class='container-wide'>
    <h2 class='text-3xl md:text-4xl font-heading text-center mb-4'>
      O que dizem sobre <span class='gradient-gold bg-clip-text text-transparent'>Patricia</span>
    </h2>
    <p class='text-muted-foreground text-center mb-16 max-w-xl mx-auto'>
      Histórias reais de quem transformou sua perspectiva com os cards.
    </p>

    <div class='grid md:grid-cols-3 gap-8'>
      {testimonials.map((testimonial) => (
        <Card variant='glass' padding='lg'>
          <div class='flex items-center gap-1 mb-4'>
            {[...Array(5)].map(() => (
              <span class='text-gold-500'>★</span>
            ))}
          </div>

          <blockquote class='text-foreground mb-6 italic font-display text-lg leading-relaxed'>
            <span class='text-gold-500'>“</span>{testimonial.quote}<span class='text-gold-500'>”</span>
          </blockquote>

          <div class='border-t border-border pt-4'>
            <div class='font-semibold text-foreground'>{testimonial.author}</div>
            <div class='text-sm text-muted-foreground'>{testimonial.location}</div>
            <Badge variant='success' class='mt-3'>
              ✓ {testimonial.result}
            </Badge>
          </div>
        </Card>
      ))}
    </div>
  </div>
</section>