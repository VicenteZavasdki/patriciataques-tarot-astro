---
import Button from '../ui/Button.astro';
import Badge from '../ui/Badge.astro';
import { siteConfig } from '../../lib/constants';

const whatsappLink = `https://wa.me/${siteConfig.whatsapp}?text=${encodeURIComponent('Olá Patricia! Gostaria de agendar uma leitura de tarot.')}`;
---

<section class='relative min-h-screen flex items-center justify-center overflow-hidden'>
  <div class='absolute inset-0 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-gold-900/20 via-background to-background'></div>

  <div class='relative z-10 container-wide py-20 text-center'>
    <div class='animate-fade-in mb-8'>
      <Badge variant='gold'>🔮 Leituras de Tarot Profundas</Badge>
    </div>

    <h1 class='animate-slide-up font-display text-5xl md:text-7xl lg:text-8xl font-bold mb-6 tracking-tight'>
      <span class='text-foreground'>Descubra seu</span>
      <br />
      <span class='gradient-gold bg-clip-text text-transparent'>Caminho</span>
      <span class='text-foreground'> com os</span>
      <br />
      <span class='text-foreground'>Cards</span>
    </h1>

    <p class='animate-slide-up text-xl md:text-2xl text-muted-foreground max-w-2xl mx-auto mb-10' style='animation-delay: 100ms;'>
      Leituras personalizadas que revelam insights profundos e guiam suas decisões com sabedoria ancestral.
    </p>

    <div class='animate-slide-up flex flex-col sm:flex-row gap-4 justify-center items-center' style='animation-delay: 200ms;'>
      <Button variant='default' size='lg' href='#agendar'>
        🔮 Agendar Leitura
      </Button>
      <Button variant='outline' size='lg' href={siteConfig.instagram}>
        📱 Seguir no Instagram
      </Button>
    </div>

    <div class='animate-slide-up mt-16 flex items-center justify-center gap-8 text-muted-foreground' style='animation-delay: 300ms;'>
      <div class='text-center'>
        <div class='text-3xl font-bold text-gold-500'>+300</div>
        <div class='text-sm'>Leituras</div>
      </div>
      <div class='w-px h-12 bg-border'></div>
      <div class='text-center'>
        <div class='text-3xl font-bold text-gold-500'>2+</div>
        <div class='text-sm'>Anos de experiência</div>
      </div>
      <div class='w-px h-12 bg-border'></div>
      <div class='text-center'>
        <div class='text-3xl font-bold text-gold-500'>Global</div>
        <div class='text-sm'>Alcance</div>
      </div>
    </div>
  </div>

  <div class='absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-background to-transparent'></div>
</section>