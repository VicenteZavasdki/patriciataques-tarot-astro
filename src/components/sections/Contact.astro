---
import LeadForm from '../islands/LeadForm';
import { siteConfig } from '../../lib/constants';
---

<section class='py-20 scroll-reveal' id='contato'>
  <div class='container-wide'>
    <h2 class='text-3xl md:text-4xl font-[family-name:var(--font-heading)] text-center mb-4 scroll-reveal'>
      Entre em <span class='gradient-gold-text'>Contato</span>
    </h2>
    <p class='text-muted-foreground text-center mb-12 max-w-xl mx-auto scroll-reveal'>
      Preencha o formulário abaixo e sua mensagem será aberta diretamente no WhatsApp.
    </p>

    <div class='max-w-2xl mx-auto'>
      <div class='bg-background-card border border-border rounded-2xl p-8 scroll-reveal'>
        <LeadForm client:visible whatsappNumber={siteConfig.whatsapp} />
      </div>

      <div class='mt-8 flex flex-col sm:flex-row items-center justify-center gap-6 scroll-reveal'>
        <div class='flex items-center gap-2 text-muted-foreground'>
          <svg class='w-5 h-5 text-gold-500' fill='none' stroke='currentColor' viewBox='0 0 24 24'>
            <path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z' />
          </svg>
          <span class='text-sm'>Resposta em até 24h</span>
        </div>
        <div class='flex items-center gap-2 text-muted-foreground'>
          <svg class='w-5 h-5 text-gold-500' fill='none' stroke='currentColor' viewBox='0 0 24 24'>
            <path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z' />
          </svg>
          <span class='text-sm'>Dados protegidos</span>
        </div>
        <div class='flex items-center gap-2 text-muted-foreground'>
          <svg class='w-5 h-5 text-gold-500' fill='none' stroke='currentColor' viewBox='0 0 24 24'>
            <path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M17 8h2a2 2 0 012 2v6a2 2 0 01-2 2h-2v4l-4-4H9a1.994 1.994 0 01-1.414-.586m0 0L11 14h4a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2v4l.586-.586z' />
          </svg>
          <span class='text-sm'>Atendimento pessoal</span>
        </div>
      </div>
    </div>
  </div>
</section>