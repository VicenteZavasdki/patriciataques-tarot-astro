---
import Card from '../ui/Card.astro';
import Button from '../ui/Button.astro';
import { pricingConfig, siteConfig } from '../../lib/constants';

const whatsappLink = `https://wa.me/${siteConfig.whatsapp}?text=${encodeURIComponent('Olá Patricia! Gostaria de saber mais sobre as leituras de tarot.')}`;

const formatPrice = (amount: number, currency: string) => {
  return new Intl.NumberFormat('pt-BR', {
    style: 'currency',
    currency
  }).format(amount);
};
---

<section class='py-20' id='precos'>
  <div class='container-wide'>
    <h2 class='text-3xl md:text-4xl font-heading text-center mb-4'>
      Investimento na sua <span class='gradient-gold bg-clip-text text-transparent'>Jornada</span>
    </h2>
    <p class='text-muted-foreground text-center mb-16 max-w-xl mx-auto'>
      Escolha a opção que se encaixa melhor na sua realidade.
    </p>

    <div class='grid md:grid-cols-2 gap-8 max-w-3xl mx-auto'>
      <Card variant='gold' padding='lg' class='text-center relative overflow-hidden'>
        <div class='absolute top-0 right-0 bg-gold-500 text-background text-xs font-bold px-3 py-1 rounded-bl-lg'>
          Brasil
        </div>
        <div class='text-muted-foreground mb-2'>Leitura para</div>
        <div class='text-4xl font-bold text-gold-400 mb-6'>
          {formatPrice(pricingConfig.brazil.amount, pricingConfig.brazil.currency)}
        </div>
        <ul class='text-left space-y-3 mb-8'>
          <li class='flex items-center gap-2 text-foreground'>
            <span class='text-gold-500'>✓</span> Sessão completa via videochamada
          </li>
          <li class='flex items-center gap-2 text-foreground'>
            <span class='text-gold-500'>✓</span> Fotos das cartas tiradas
          </li>
          <li class='flex items-center gap-2 text-foreground'>
            <span class='text-gold-500'>✓</span> Gravação em áudio
          </li>
          <li class='flex items-center gap-2 text-foreground'>
            <span class='text-gold-500'>✓</span> Análise escrita detalhada
          </li>
        </ul>
        <Button variant='default' size='lg' href={whatsappLink} class='w-full'>
          Agendar no WhatsApp
        </Button>
      </Card>

      <Card variant='hover' padding='lg' class='text-center relative overflow-hidden'>
        <div class='absolute top-0 right-0 bg-muted-foreground text-background text-xs font-bold px-3 py-1 rounded-bl-lg'>
          Europa/Global
        </div>
        <div class='text-muted-foreground mb-2'>Leitura para</div>
        <div class='text-4xl font-bold text-foreground mb-6'>
          {formatPrice(pricingConfig.europe.amount, pricingConfig.europe.currency)}
        </div>
        <ul class='text-left space-y-3 mb-8'>
          <li class='flex items-center gap-2 text-foreground'>
            <span class='text-gold-500'>✓</span> Sessão completa via videochamada
          </li>
          <li class='flex items-center gap-2 text-foreground'>
            <span class='text-gold-500'>✓</span> Fotos das cartas tiradas
          </li>
          <li class='flex items-center gap-2 text-foreground'>
            <span class='text-gold-500'>✓</span> Gravação em áudio
          </li>
          <li class='flex items-center gap-2 text-foreground'>
            <span class='text-gold-500'>✓</span> Análise escrita detalhada
          </li>
        </ul>
        <Button variant='outline' size='lg' href='#agendar' class='w-full'>
          Agendar Online
        </Button>
      </Card>
    </div>

    <p class='text-center text-muted-foreground text-sm mt-8'>
      Pagamento via transferência bancária, PIX ou link de pagamento.
    </p>
  </div>
</section>