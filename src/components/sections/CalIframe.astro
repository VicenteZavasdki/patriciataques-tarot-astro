---
interface Props {
  calLink?: string;
  title?: string;
}

const { calLink = 'patriciataques/leitura-de-tarot', title = 'Agendar Leitura de Tarot' } = Astro.props;

const iframeUrl = `https://cal.com/${calLink}?embed=true&hideEventTypeDetails=1&layout=month_view`;
---

<div class='cal-iframe-container'>
  <div class='cal-iframe-header'>
    <h3 class='text-xl font-heading mb-2'>{title}</h3>
    <p class='text-muted-foreground text-sm mb-4'>Selecione um horário disponível abaixo</p>
  </div>

  <iframe
    src={iframeUrl}
    width='100%'
    height='700'
    loading='lazy'
    title={title}
    class='rounded-2xl border border-border bg-background-card'
    style='border: none; min-height: 700px;'
    allow='camera; microphone; autoplay; encrypted-media'
  />

  <div class='mt-4 text-center'>
    <p class='text-xs text-muted-foreground'>
      Ao agendar, você receberá um link de videochamada por email.
    </p>
  </div>
</div>

<style>
  .cal-iframe-container {
    width: 100%;
  }

  iframe {
    transition: opacity 0.3s ease;
  }

  iframe:not([src]) {
    opacity: 0;
  }
</style>