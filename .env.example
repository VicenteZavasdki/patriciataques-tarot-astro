# Environment Variables Example
# Copy this file to .env and fill in your values

# Site Configuration
PUBLIC_SITE_URL=https://patriciataques.com

# Cal.com
PUBLIC_CALCOM_LINK=patriciataques/tarot-reading

# WhatsApp (Brazil format - no + or 00)
PUBLIC_WHATSAPP=5511999999999

# Stripe (for future payment integration)
STRIPE_SECRET_KEY=sk_test_your_key_here
PUBLIC_STRIPE_KEY=pk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Cloudflare (auto-provided in Cloudflare Pages)
# NODE_VERSION=22.12.0